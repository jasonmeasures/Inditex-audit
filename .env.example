# ── 7501 Audit Tool — environment variables ──────────────────────────────────
# Copy to .env and fill in values. The .env file is loaded by start.sh.
# NEVER commit .env to git.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
PGHOST=localhost
PGPORT=5432
# PGUSER defaults to your OS username
# PGPASSWORD is empty for local trust auth
PGDATABASE=inditex_audit

# ── Flask ─────────────────────────────────────────────────────────────────────
PORT=5252
# Generate once with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Must be stable across restarts — changing it invalidates all active sessions.
APP_SECRET_KEY=CHANGE_ME_generate_a_random_hex_string

# ── Microsoft Entra ID SSO ────────────────────────────────────────────────────
# App registration → Overview
ENTRA_CLIENT_ID=your-app-client-id-here
# App registration → Certificates & secrets → New client secret
ENTRA_CLIENT_SECRET=your-client-secret-here
# Your company's tenant ID (users from this tenant get role='admin' on first login)
# App registration → Overview → Directory (tenant) ID
ADMIN_TENANT_ID=your-tenant-id-here
# Leave as 'common' for multi-tenant (any Microsoft org + personal accounts)
ENTRA_AUTHORITY=https://login.microsoftonline.com/common
# Must match exactly what you registered in App registration → Authentication
ENTRA_REDIRECT_URI=http://localhost:5252/auth/callback

# ── Local development ─────────────────────────────────────────────────────────
# Set to 'true' to skip Microsoft login entirely.
# You will be auto-signed in as "Dev User (SSO bypassed)" with admin role.
# Never set this to true in production.
DEV_BYPASS_SSO=true
