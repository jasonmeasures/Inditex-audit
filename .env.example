# Copy to .env and fill in for local dev / first admin seed.
# start.sh and inditex_audit_server.py load .env when present.

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=inditex_audit

# Flask
PORT=5252
HOSTNAME_PRETTY=7501-audit.local

# Auth — required for sign-in; set JWT_SECRET in production
JWT_SECRET=change-me-in-production
JWT_EXPIRES_HOURS=8

# First-run admin (only created when users table is empty)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=
